{
  "manifest_version": 3,
  "name": "SLI Dev Tools",
  "version": "4.0.0",
  "description": "Devtools extension for working on SLI Clients",
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "devtools_page": "devtools.html",
  "omnibox": {
    "keyword": "sli_devtools"
  },
  "icons": {
    "16": "img/icon-16.png",
    "128": "img/icon-128.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "http://*/",
    "https://*/"
  ],
  "action": {
    "default_icon": {
      "16": "img/icon-16.png",
      "128": "img/icon-128.png"
    }
  }
}